# ── Database ──────────────────────────────────────────────────────────────────
# Docker Compose service name (postgres) used when running via docker-compose
DATABASE_URL=postgresql://threatradar:password@postgres:5432/threatradar

# Local development (no Docker)
# DATABASE_URL=postgresql://localhost/threatradar

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── API Keys ──────────────────────────────────────────────────────────────────
NVD_API_KEY=your_nvd_api_key_here

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
